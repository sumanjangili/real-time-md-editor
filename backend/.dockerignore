# ---- Node / JS artefacts (frontend) ----
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log
yarn.lock
.pnpm-store/

# ---- Rust artefacts (backend) ----
backend/target/          # compiled binaries – safe to ignore
backend/.cargo/          # cargo caches – safe to ignore

# ---- Generic ----
.git
.gitignore
.gitmodules
.DS_Store
Thumbs.db
*.swp
*.swo

# ---- Secrets / env files (never copy into images) ----
.env
*.env.*
.secret*
*.pem
*.key

# ---- Docker artefacts (not needed in the image) ----
Dockerfile*
docker-compose.yml
.dockerignore
