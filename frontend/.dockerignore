# ---- Node / JS artefacts (frontend) ----
node_modules
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log
yarn.lock
.pnpm-store/

# ---- Rust artefacts (backend) ----
backend/target/          # compiled binaries – safe to ignore
backend/.cargo/          # cargo caches – safe to ignore

# ---- Generic ----
.git
.gitignore
.gitmodules
.DS_Store
.vscode
.idea
Thumbs.db
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# Build artefacts that are not needed for the Docker build
dist
coverage
*.log
*.tmp
.DS_Store
.git
.gitignore

# ---- Secrets / env files (never copy into images) ----
.env
*.env.*
.secret*
*.pem
*.key

# ---- Docker artefacts (not needed in the image) ----
Dockerfile*
docker-compose.yml
.dockerignore
